    "Ask our AI assistant anything about ingredients, substitutionsm technique, or tips!": {
      "localizations": {
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Запитайте AI-помічника про інгредієнти, заміни, техніку або поради!"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapytaj asystenta AI o składniki, zamienniki, techniki lub wskazówki!"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Frag den KI-Assistenten nach Zutaten, Alternativen, Techniken oder Tipps!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Demandez à l’assistant IA des conseils sur les ingrédients, substitutions, techniques ou astuces !"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pregunta al asistente de IA sobre ingredientes, sustituciones, técnicas o consejos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiedi all’assistente AI informazioni su ingredienti, sostituzioni, tecniche o consigli!"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pergunte ao assistente de IA sobre ingredientes, substituições, técnicas ou dicas!"
          }
        }
      }
